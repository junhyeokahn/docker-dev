# Build
BUILD_CONTEXT=../..
DOCKERFILE_PATH=Dockerfile
BASE_IMAGE=ubuntu:24.04
ZK_VERSION=v0.15.2

# Image/container identity
IMAGE_NAME=foo-dev:local
CONTAINER_NAME=foo-dev

# Runtime user inside container
DEV_USER=dev
DEV_UID=1000
DEV_GID=1000
DOCKER_HOME=/home/dev

# Workspace in container
WORKDIR=/workspace

# Host paths
HOST_PROJECT_DIRECTORY=/absolute/path/to/foo
HOST_NVIM_CONFIG_DIRECTORY=/absolute/path/to/your/nvim
HOST_NVIM_DATA_DIRECTORY=/absolute/path/to/docker-dev/nvim-data/foo
HOST_NVIM_STATE_DIRECTORY=/absolute/path/to/docker-dev/nvim-state/foo
HOST_NOTEBOOK_DIRECTORY=/absolute/path/to/your/notebook
