# Build
BUILD_CONTEXT=../..
DOCKERFILE_PATH=ubuntu.Dockerfile
BASE_IMAGE=gr00t-dev

# Image/container identity
IMAGE_NAME=gr00t-dev:jahn
CONTAINER_NAME=gr00t-dev

# Runtime user inside container
DEV_USER=ubuntu
DEV_UID=1000
DEV_GID=1000
DOCKER_HOME=/home/ubuntu

# Workspace in container
WORKDIR=/workspace/gr00t

# Host paths
HOST_PROJECT_DIRECTORY=$HOME/workspace/Isaac-GR00T
HOST_NVIM_CONFIG_DIRECTORY=$HOME/.config/nvim
HOST_NVIM_DATA_DIRECTORY=$HOME/workspace/docker-dev/nvim-data/ubuntu-22.04-amd64
HOST_NOTEBOOK_DIRECTORY=$HOME/notebook
